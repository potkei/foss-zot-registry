# Registry credentials — EXAMPLE ONLY
# Copy to registry-credentials.env (gitignored) and fill in real values.
# Real secrets stored in your secrets manager (Vault, AWS Secrets Manager, etc.)

REGISTRY_URL=registry.company.com
REGISTRY_USERNAME=REPLACE_ME
REGISTRY_PASSWORD=REPLACE_ME
# Or use token-based auth:
REGISTRY_TOKEN=REPLACE_ME
