# Test runner image — BATS + Go (for building jsonq) + bash tools
# Used by: docker compose -f .local/docker-compose.test.yml run test
# Uses golang base image for correct multi-arch Go (amd64 + arm64)
ARG GO_VERSION=1.22.3
FROM golang:${GO_VERSION}-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
      bats \
      bash \
      git \
      ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /repo

ENTRYPOINT ["bats", "--recursive", ".tools/tests/"]
